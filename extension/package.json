{
  "name": "chapter-review",
  "displayName": "Chapter Review",
  "description": "Review a branch as logical chapters generated by the chapter-review skill",
  "version": "0.3.0",
  "publisher": "kevinboss",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kevinboss/chapter-review.git",
    "directory": "extension"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "SCM Providers"
  ],
  "activationEvents": [
    "workspaceContains:.git"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "chapter-review",
          "title": "Chapter Review",
          "icon": "media/chapter-review.svg"
        }
      ]
    },
    "views": {
      "chapter-review": [
        {
          "id": "chapterReview",
          "name": "Chapters",
          "contextualTitle": "Chapter Review"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "chapterReview",
        "contents": "No chapter manifest found (.git/chapter-review/chapters.json).\nGenerate one with the chapter-review skill in your coding agent, then this view renders the branch as reviewable chapters.\n[Install or update the skill](command:chapterReview.installSkill)"
      }
    ],
    "commands": [
      {
        "command": "chapterReview.refresh",
        "title": "Refresh",
        "category": "Chapter Review",
        "icon": "$(refresh)"
      },
      {
        "command": "chapterReview.viewAsTree",
        "title": "View as Tree",
        "category": "Chapter Review",
        "icon": "$(list-tree)"
      },
      {
        "command": "chapterReview.viewAsList",
        "title": "View as List",
        "category": "Chapter Review",
        "icon": "$(list-flat)"
      },
      {
        "command": "chapterReview.openDiff",
        "title": "Open Diff",
        "category": "Chapter Review"
      },
      {
        "command": "chapterReview.resetProgress",
        "title": "Reset Review Progress",
        "category": "Chapter Review"
      },
      {
        "command": "chapterReview.installSkill",
        "title": "Install or Update Skill",
        "category": "Chapter Review"
      },
      {
        "command": "chapterReview.openIssue",
        "title": "Open Issue",
        "category": "Chapter Review"
      },
      {
        "command": "chapterReview.openFile",
        "title": "Open File",
        "category": "Chapter Review",
        "icon": "$(go-to-file)"
      },
      {
        "command": "chapterReview.resolveIssue",
        "title": "Toggle Issue Resolved",
        "category": "Chapter Review",
        "icon": "$(check)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "chapterReview.viewAsTree",
          "when": "view == chapterReview && chapterReview.viewMode == list",
          "group": "navigation@1"
        },
        {
          "command": "chapterReview.viewAsList",
          "when": "view == chapterReview && chapterReview.viewMode == tree",
          "group": "navigation@1"
        },
        {
          "command": "chapterReview.refresh",
          "when": "view == chapterReview",
          "group": "navigation@2"
        },
        {
          "command": "chapterReview.resetProgress",
          "when": "view == chapterReview"
        },
        {
          "command": "chapterReview.installSkill",
          "when": "view == chapterReview"
        }
      ],
      "editor/title": [
        {
          "command": "chapterReview.openFile",
          "when": "resourceScheme == chapter-review-patched || resourceScheme == chapter-review-git",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "chapterReview.resolveIssue",
          "when": "view == chapterReview && viewItem == chapterReviewIssue",
          "group": "inline"
        }
      ],
      "commandPalette": [
        {
          "command": "chapterReview.openDiff",
          "when": "false"
        },
        {
          "command": "chapterReview.openIssue",
          "when": "false"
        },
        {
          "command": "chapterReview.openFile",
          "when": "false"
        },
        {
          "command": "chapterReview.resolveIssue",
          "when": "false"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -w -p .",
    "bundle-skill": "node scripts/bundle-skill.mjs",
    "build": "npm run compile && npm run bundle-skill",
    "vscode:prepublish": "npm run build",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.2.0",
    "typescript": "^5.5.0"
  }
}
